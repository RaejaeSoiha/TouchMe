generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}
enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}
enum IdentityProvider {
  EMAIL
  PHONE
  GOOGLE
  APPLE
}
enum Gender {
  WOMAN
  MAN
  NON_BINARY
  OTHER
}
enum MessageType {
  TEXT
  IMAGE
  VOICE
  SYSTEM
}
enum DeliveryStatus {
  SENT
  DELIVERED
  READ
}
enum ReportReason {
  HARASSMENT
  SPAM
  FAKE_PROFILE
  INAPPROPRIATE_CONTENT
  UNDERAGE
  SCAM
  OTHER
}
enum ReportStatus {
  OPEN
  REVIEWING
  ACTIONED
  DISMISSED
}
enum MediaStatus {
  PENDING
  APPROVED
  REJECTED
}
enum SubscriptionStatus {
  INCOMPLETE
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}
enum NotificationType {
  MATCH
  MESSAGE
  LIKE
  FRIEND_REQUEST
  SYSTEM
  SUBSCRIPTION
}
enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}
enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id                  String             @id @default(uuid()) @db.Uuid
  email               String?            @unique
  phone               String?            @unique
  passwordHash        String?
  role                 UserRole           @default(USER)
  status               UserStatus         @default(PENDING)
  emailVerifiedAt      DateTime?
  phoneVerifiedAt      DateTime?
  lastActiveAt         DateTime            @default(now())
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  deletedAt            DateTime?
  profile              Profile?
  identities           AuthIdentity[]
  refreshTokens        RefreshToken[]
  verificationTokens   VerificationToken[]
  devices              Device[]
  sentFriendRequests     FriendRequest[]     @relation("FriendRequestSender")
  receivedFriendRequests FriendRequest[]   @relation("FriendRequestRecipient")
  friendships            Friendship[]        @relation("FriendshipUser")
  friendsOf              Friendship[]        @relation("FriendshipFriend")
  conversationMembers    ConversationMember[]
  messages             Message[]
  messageReceipts      MessageReceipt[]
  blocksCreated        Block[]             @relation("Blocker")
  blocksReceived       Block[]             @relation("Blocked")
  reportsCreated       Report[]            @relation("Reporter")
  reportsReceived      Report[]            @relation("Reported")
  reportsReviewed      Report[]            @relation("Reviewer")
  subscriptions        Subscription[]
  boosts               Boost[]
  notifications        Notification[]
  auditLogs            AuditLog[]           @relation("AuditActor")
  moderationCases      ModerationCase[]     @relation("ModeratedUser")
  moderationActions    ModerationCase[]     @relation("Moderator")
  posts                Post[]
  postLikes            PostLike[]
  postComments         PostComment[]

  @@index([status, lastActiveAt])
}

model AuthIdentity {
  id                String           @id @default(uuid()) @db.Uuid
  userId            String           @db.Uuid
  provider          IdentityProvider
  providerSubject   String
  createdAt         DateTime         @default(now())
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerSubject])
  @@index([userId])
}

model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  familyId    String    @db.Uuid
  tokenHash   String
  userAgent   String?
  ipHash      String?
  expiresAt   DateTime
  revokedAt   DateTime?
  replacedBy  String?   @db.Uuid
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, familyId])
  @@index([expiresAt])
}

model VerificationToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  purpose    String
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, purpose])
}

model Profile {
  id                  String             @id @default(uuid()) @db.Uuid
  userId              String             @unique @db.Uuid
  displayName         String
  birthDate           DateTime
  gender              Gender
  showMe              Gender[]
  bio                  String?            @db.VarChar(1000)
  occupation          String?            @db.VarChar(120)
  education           String?            @db.VarChar(120)
  city                 String?            @db.VarChar(120)
  countryCode          String?            @db.Char(2)
  latitude             Decimal?           @db.Decimal(9, 6)
  longitude            Decimal?           @db.Decimal(9, 6)
  minAge               Int                @default(18)
  maxAge               Int                @default(99)
  maxDistanceKm        Int                @default(50)
  passportLatitude     Decimal?           @db.Decimal(9, 6)
  passportLongitude    Decimal?           @db.Decimal(9, 6)
  verificationStatus  VerificationStatus @default(UNVERIFIED)
  discoverable         Boolean            @default(true)
  completedAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos               Photo[]
  interests            ProfileInterest[]
  @@index([gender, discoverable])
  @@index([birthDate])
}

model Photo {
  id          String      @id @default(uuid()) @db.Uuid
  profileId   String      @db.Uuid
  storageKey  String      @unique
  url         String
  position    Int
  status      MediaStatus @default(PENDING)
  blurHash    String?
  createdAt   DateTime    @default(now())
  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  @@unique([profileId, position])
}

model Interest {
  id        String            @id @default(uuid()) @db.Uuid
  slug      String            @unique
  label     String
  active    Boolean           @default(true)
  profiles  ProfileInterest[]
}

model ProfileInterest {
  profileId  String   @db.Uuid
  interestId String   @db.Uuid
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  interest   Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)
  @@id([profileId, interestId])
}

model FriendRequest {
  id          String              @id @default(uuid()) @db.Uuid
  senderId    String              @db.Uuid
  recipientId String              @db.Uuid
  status      FriendRequestStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  sender      User                @relation("FriendRequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User                @relation("FriendRequestRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  @@unique([senderId, recipientId])
  @@index([recipientId, status])
}

model Friendship {
  userId    String   @db.Uuid
  friendId  String   @db.Uuid
  createdAt DateTime @default(now())
  user      User     @relation("FriendshipUser", fields: [userId], references: [id], onDelete: Cascade)
  friend    User     @relation("FriendshipFriend", fields: [friendId], references: [id], onDelete: Cascade)
  @@id([userId, friendId])
  @@index([friendId])
}

model Conversation {
  id        String               @id @default(uuid()) @db.Uuid
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  members   ConversationMember[]
  messages  Message[]
  @@index([updatedAt(sort: Desc)])
}

model ConversationMember {
  conversationId String       @db.Uuid
  userId         String       @db.Uuid
  joinedAt       DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String          @id @default(uuid()) @db.Uuid
  conversationId String          @db.Uuid
  senderId       String          @db.Uuid
  clientId       String          @db.Uuid
  type           MessageType
  body           String?         @db.VarChar(4000)
  mediaUrl       String?
  mediaSeconds   Int?
  createdAt      DateTime        @default(now())
  deletedAt      DateTime?
  conversation   Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User            @relation(fields: [senderId], references: [id], onDelete: Restrict)
  receipts       MessageReceipt[]
  @@unique([senderId, clientId])
  @@index([conversationId, createdAt(sort: Desc)])
}

model MessageReceipt {
  messageId String         @db.Uuid
  userId    String         @db.Uuid
  status    DeliveryStatus @default(SENT)
  updatedAt DateTime       @updatedAt
  message   Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([messageId, userId])
}

model Device {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  platform  String
  pushToken String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, active])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt(sort: Desc)])
}

model Block {
  blockerId String   @db.Uuid
  blockedId String   @db.Uuid
  createdAt DateTime @default(now())
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  @@id([blockerId, blockedId])
  @@index([blockedId])
}

model Report {
  id          String       @id @default(uuid()) @db.Uuid
  reporterId  String       @db.Uuid
  reportedId  String       @db.Uuid
  reviewerId  String?      @db.Uuid
  reason      ReportReason
  details     String?      @db.VarChar(2000)
  evidence    Json?
  status      ReportStatus @default(OPEN)
  resolution  String?      @db.VarChar(2000)
  createdAt   DateTime     @default(now())
  reviewedAt  DateTime?
  reporter    User         @relation("Reporter", fields: [reporterId], references: [id], onDelete: Restrict)
  reported    User         @relation("Reported", fields: [reportedId], references: [id], onDelete: Restrict)
  reviewer    User?        @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  @@index([status, createdAt])
  @@index([reportedId])
}

model ModerationCase {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String      @db.Uuid
  moderatorId String?     @db.Uuid
  source      String
  sourceId    String?
  status      String
  notes       String?     @db.VarChar(4000)
  createdAt   DateTime    @default(now())
  resolvedAt  DateTime?
  user        User        @relation("ModeratedUser", fields: [userId], references: [id], onDelete: Restrict)
  moderator   User?       @relation("Moderator", fields: [moderatorId], references: [id], onDelete: SetNull)
  @@index([status, createdAt])
}

model Plan {
  id                  String         @id @default(uuid()) @db.Uuid
  code                String         @unique
  name                String
  stripePriceId       String         @unique
  priceCents          Int
  currency            String         @default("usd")
  interval            String
  unlimitedLikes      Boolean        @default(false)
  passportMode        Boolean        @default(false)
  monthlyBoosts       Int            @default(0)
  active              Boolean        @default(true)
  subscriptions       Subscription[]
}

model Subscription {
  id                    String             @id @default(uuid()) @db.Uuid
  userId                String             @db.Uuid
  planId                String             @db.Uuid
  stripeCustomerId      String
  stripeSubscriptionId  String             @unique
  status                SubscriptionStatus
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  user                  User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  plan                  Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  @@index([userId, status])
}

model Boost {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, endsAt])
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorId     String?  @db.Uuid
  action      String
  targetType  String
  targetId    String?
  metadata    Json?
  ipHash      String?
  createdAt   DateTime @default(now())
  actor       User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  @@index([targetType, targetId])
  @@index([createdAt(sort: Desc)])
}

enum PostVisibility {
  FRIENDS_ONLY
  ONLY_ME
}

model Post {
  id            String         @id @default(uuid()) @db.Uuid
  authorId      String         @db.Uuid
  body          String         @db.VarChar(4000)
  mediaUrl      String?
  mediaType     String?
  visibility    PostVisibility @default(FRIENDS_ONLY)
  allowComments Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes         PostLike[]
  comments      PostComment[]

  @@index([authorId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model PostLike {
  postId    String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
}

model PostComment {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @db.Uuid
  authorId  String   @db.Uuid
  body      String   @db.VarChar(2000)
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model DailyMetric {
  date            DateTime @id @db.Date
  activeUsers     Int      @default(0)
  signups         Int      @default(0)
  matches         Int      @default(0)
  friendRequests  Int      @default(0)
  messages        Int      @default(0)
  revenueCents    Int      @default(0)
  retainedDay7    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
