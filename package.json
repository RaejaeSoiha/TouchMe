{
  "name": "touchme",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["apps/api", "apps/admin"],
  "scripts": {
    "build": "npm run build --workspace @touchme/api && npm run build --workspace @touchme/admin",
    "test": "npm run test --workspace @touchme/api",
    "lint": "npm run lint --workspace @touchme/api && npm run lint --workspace @touchme/admin",
    "dev:api": "npm run start:dev --workspace @touchme/api",
    "dev:admin": "npm run dev --workspace @touchme/admin",
    "db:migrate": "npm run prisma:migrate --workspace @touchme/api",
    "db:seed": "npm run prisma:seed --workspace @touchme/api",
    "test:security": "node scripts/security-smoke.mjs",
    "test:load": "node scripts/load-smoke.mjs",
    "verify:production-env": "node scripts/verify-production-env.mjs"
  },
  "engines": { "node": ">=22" },
  "overrides": { "uuid": "11.1.1" }
}
